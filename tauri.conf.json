{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "claude-overlay",
  "version": "0.1.0",
  "identifier": "dev.adrie.claudeoverlay",
  "build": {
    "frontendDist": "./ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "overlay",
        "url": "index.html",
        "title": "claude-overlay",
        "width": 720,
        "height": 80,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": false,
        "focus": false
      },
      {
        "label": "popover",
        "url": "popover.html",
        "title": "claude-overlay-popover",
        "width": 288,
        "height": 100,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
